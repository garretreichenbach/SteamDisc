<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:SteamDisc.Skin.Controls"
        x:Class="SteamDisc.Launcher.MainWindow"
        Width="620" Height="460" CanResize="False"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/SteamDisc.ico"
        Title="SteamDisc">

  <Window.Styles>
    <Style Selector="Button.tool">
      <Setter Property="Background" Value="#1E1F24" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2A2C33" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="32,28,32,20">

    <StackPanel Grid.Row="0" Spacing="4">
      <TextBlock Text="SteamDisc" FontSize="28" FontWeight="Bold" />
      <TextBlock Text="Turn a game you own into physical, skinned media." Opacity="0.7" FontSize="14" />
    </StackPanel>

    <StackPanel Grid.Row="1" Spacing="14" VerticalAlignment="Center">

      <Border x:Name="UpdateBanner" IsVisible="False" CornerRadius="8" Padding="14"
              Background="#16241A" BorderBrush="#3FB950" BorderThickness="1">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
            <TextBlock x:Name="UpdateTitle" FontWeight="SemiBold" FontSize="14" />
            <TextBlock x:Name="UpdateDetail" Opacity="0.75" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>
          <Button x:Name="UpdateButton" Grid.Column="1" Content="Update now" Click="OnUpdate"
                  VerticalAlignment="Center" Padding="16,8" />
        </Grid>
      </Border>

      <Button Classes="tool" Click="OnCreate">
        <StackPanel Spacing="4">
          <TextBlock Text="Create a disc" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Text="Pick an installed game, dress the disc, and build an ISO to burn."
                     Opacity="0.7" FontSize="13" TextWrapping="Wrap" />
        </StackPanel>
      </Button>

      <Button Classes="tool" Click="OnInstall">
        <StackPanel Spacing="4">
          <TextBlock Text="Install a disc" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Text="Run a SteamDisc you already built or burned, from a folder or drive."
                     Opacity="0.7" FontSize="13" TextWrapping="Wrap" />
        </StackPanel>
      </Button>

      <TextBlock x:Name="Status" Foreground="#F5B32B" FontSize="12.5" TextWrapping="Wrap"
                 IsVisible="False" />
    </StackPanel>

    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="Personal-archival tool for games you own." Opacity="0.5" FontSize="12" />
        <TextBlock x:Name="VersionLabel" Opacity="0.4" FontSize="12" />
      </StackPanel>
      <controls:SteamBadge Grid.Column="1" Tint="#9AA0AA" GlyphSize="18" Opacity="0.8"
                           VerticalAlignment="Center" />
    </Grid>
  </Grid>
</Window>
