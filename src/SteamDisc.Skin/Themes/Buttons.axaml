<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    The skin's buttons carry their own control theme rather than restyling the Fluent one.

    Two rules keep this stable:

      * The template is a single named Border. Layering colours onto the stock Button template
        left our setters and the theme's own state setters both driving one background, and they
        re-assert it against each other on every render pass - which shows up as a flicker.

      * Nothing here binds. A ControlTheme in a resource dictionary has no x:DataType, so a
        {Binding} in a Setter has no compiled context to resolve against and silently yields
        nothing - which is why the accent fill went missing. Colours are therefore set on the
        Button elements in the views, where the view model type is known, and reach the template
        through TemplateBinding. States only adjust opacity, which needs no brush at all.
  -->

  <ControlTheme x:Key="SkinPrimaryButton" TargetType="Button">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="26,12" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Foreground="{TemplateBinding Foreground}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover /template/ Border#Root">
      <Setter Property="Opacity" Value="0.86" />
    </Style>
    <Style Selector="^:pressed /template/ Border#Root">
      <Setter Property="Opacity" Value="0.72" />
    </Style>
    <Style Selector="^:disabled /template/ Border#Root">
      <Setter Property="Opacity" Value="0.45" />
    </Style>
  </ControlTheme>

  <!-- Outlined, for Exit / secondary actions. -->
  <ControlTheme x:Key="SkinQuietButton" TargetType="Button">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="22,12" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Foreground="{TemplateBinding Foreground}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover /template/ Border#Root">
      <Setter Property="Opacity" Value="0.72" />
    </Style>
    <Style Selector="^:pressed /template/ Border#Root">
      <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="^:disabled /template/ Border#Root">
      <Setter Property="Opacity" Value="0.45" />
    </Style>
  </ControlTheme>

  <!-- Borderless, for the Modern card's quieter actions. -->
  <ControlTheme x:Key="SkinLinkButton" TargetType="Button">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="Root"
                Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Foreground="{TemplateBinding Foreground}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover /template/ Border#Root">
      <Setter Property="Opacity" Value="0.7" />
    </Style>
    <Style Selector="^:pressed /template/ Border#Root">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
