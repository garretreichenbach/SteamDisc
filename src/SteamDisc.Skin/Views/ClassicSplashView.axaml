<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skin="using:SteamDisc.Skin"
             xmlns:controls="using:SteamDisc.Skin.Controls"
             xmlns:sys="using:System"
             x:Class="SteamDisc.Skin.Views.ClassicSplashView"
             x:DataType="skin:SkinnedInstallerViewModel">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://SteamDisc.Skin/Themes/Buttons.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <!-- Bottom corners only: Windows already rounds the window itself, and rounding the top too
       just clips the title bar awkwardly. -->
  <Border CornerRadius="0,0,10,10" ClipToBounds="True" Background="{Binding BackgroundBrush}">
    <Grid>
    <!-- Layer 1: full-bleed key art. Null source simply shows nothing. -->
    <Image Source="{Binding BackgroundImage}" Stretch="UniformToFill" />

    <!-- Layer 2: a wash so text stays legible over any art. -->
    <Border Background="{Binding ScrimBrush}" />

    <!-- Layer 3: title bar, in Steam's blue-grey, so the mark has something to sit on. -->
    <Border VerticalAlignment="Top" Height="42" Background="#2A475E">
      <Grid Margin="12,0" ColumnDefinitions="Auto,*,Auto">
        <Button Grid.Column="0" Theme="{StaticResource SkinLinkButton}" Background="Transparent"
                Foreground="#C7D5E0" FontSize="12.5" Padding="6,4" VerticalAlignment="Center"
                Content="{Binding ProductLabel}" Command="{Binding OpenProjectCommand}"
                ToolTip.Tip="Open the SteamDisc project page" />
        <Button Grid.Column="2" Theme="{StaticResource SkinLinkButton}" Background="Transparent"
                Padding="6,4" VerticalAlignment="Center" Command="{Binding OpenSteamCommand}"
                ToolTip.Tip="Open Steam">
          <controls:SteamBadge Tint="#C7D5E0" GlyphSize="18" />
        </Button>
      </Grid>
    </Border>

    <!-- Layer 4: content, cleared of the bar above. -->
    <Grid Margin="44,66,44,44" RowDefinitions="Auto,*">

      <!-- Masthead: the title logo, or the title as text when there is no logo. -->
      <Panel Grid.Row="0" HorizontalAlignment="Left">
        <Image Source="{Binding LogoImage}" MaxHeight="120" MaxWidth="460"
               Stretch="Uniform" HorizontalAlignment="Left"
               IsVisible="{Binding LogoImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
        <TextBlock Text="{Binding GameTitle}" FontSize="44" FontWeight="Bold"
                   FontFamily="{Binding HeadingFont}" Foreground="{Binding TextBrush}"
                   IsVisible="{Binding LogoImage, Converter={x:Static ObjectConverters.IsNull}}" />
      </Panel>

      <!-- Stage panels share the lower region; only one is visible at a time. -->

      <!-- WELCOME -->
      <Grid Grid.Row="1" IsVisible="{Binding IsWelcome}" RowDefinitions="*,Auto">
        <!-- Scrolls rather than overflowing: a long blurb plus warnings would otherwise run
             straight over the buttons below. -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
        <StackPanel VerticalAlignment="Bottom" Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="{Binding WelcomeBody}" TextWrapping="Wrap" FontSize="18"
                     FontFamily="{Binding BodyFont}" Foreground="{Binding TextBrush}" />
          <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto" HorizontalAlignment="Left"
                        IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="13.5"
                       FontFamily="{Binding BodyFont}" Foreground="{Binding TextMutedBrush}" />
          </ScrollViewer>
          <Border IsVisible="{Binding UpdateNotice, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Background="#22F5B32B" CornerRadius="4" Padding="10,7" Margin="0,4,0,0" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="⚠" FontSize="14" Foreground="#F5B32B" VerticalAlignment="Center" />
              <TextBlock Text="{Binding UpdateNotice}" TextWrapping="Wrap" FontSize="12.5" MaxWidth="520"
                         Foreground="#F6D79A" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
          <StackPanel Spacing="2" Margin="0,8,0,0">
            <TextBlock Text="{Binding InstallTargetText}" FontSize="13" Foreground="{Binding TextMutedBrush}" />
            <TextBlock Text="{Binding SizeText}" FontSize="13" Foreground="{Binding TextMutedBrush}" />
            <TextBlock Text="{Binding FreeText}" FontSize="13" Foreground="{Binding TextMutedBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,6,0,0"
                      IsVisible="{Binding ShowLibraryChooser}">
            <TextBlock Text="Install to" VerticalAlignment="Center" Foreground="{Binding TextMutedBrush}" />
            <ComboBox ItemsSource="{Binding LibraryOptions}" SelectedItem="{Binding SelectedLibraryOption}"
                      MinWidth="320" />
          </StackPanel>
          <StackPanel Spacing="1" Margin="0,2,0,0">
            <CheckBox Content="{Binding LaunchOptionText}" IsChecked="{Binding LaunchWhenFinished}"
                      Foreground="{Binding TextBrush}" />
            <CheckBox Content="{Binding VerifyOptionText}" IsChecked="{Binding VerifyAfterInstall}"
                      Foreground="{Binding TextBrush}" />
          </StackPanel>
          <ItemsControl ItemsSource="{Binding Warnings}" Margin="0,6,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="sys:String">
                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12.5" Foreground="#F5B32B" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,24,0,0" HorizontalAlignment="Left">
          <Button Theme="{StaticResource SkinPrimaryButton}" Background="{Binding AccentBrush}" Foreground="White" Content="{Binding PrimaryButtonText}"
                  Command="{Binding PrimaryCommand}" IsEnabled="{Binding IsPrimaryEnabled}" />
          <Button Theme="{StaticResource SkinQuietButton}" Background="Transparent" Foreground="{Binding TextBrush}" BorderBrush="{Binding TextMutedBrush}" Content="{Binding ExitButtonText}" Command="{Binding ExitCommand}" />
          <Button Theme="{StaticResource SkinQuietButton}" Background="Transparent" Foreground="{Binding TextBrush}" BorderBrush="{Binding TextMutedBrush}" Content="{Binding StoreButtonText}" Command="{Binding StoreCommand}"
                  IsVisible="{Binding ShowStoreButton}" />
        </StackPanel>
      </Grid>

      <!-- INSTALLING -->
      <Grid Grid.Row="1" IsVisible="{Binding IsInstalling}" RowDefinitions="*,Auto">
        <!-- Fixed width, not MaxWidth: a left-aligned panel sizes to its widest child, so the
             changing file name would otherwise stretch and shrink the progress bar with it. -->
        <StackPanel Grid.Row="0" VerticalAlignment="Bottom" Spacing="10" Width="720" HorizontalAlignment="Left">
          <TextBlock Text="{Binding PhaseText}" FontSize="22" FontWeight="SemiBold"
                     FontFamily="{Binding HeadingFont}" Foreground="{Binding TextBrush}" />
          <TextBlock Text="{Binding StatusLine}" FontSize="13" Foreground="{Binding TextMutedBrush}"
                     TextTrimming="CharacterEllipsis" />
          <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressFraction}"
                       IsIndeterminate="{Binding IsIndeterminate}" Height="10"
                       Foreground="{Binding AccentBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="24">
            <TextBlock Text="{Binding ThroughputText}" FontSize="13" Foreground="{Binding TextMutedBrush}" />
            <TextBlock Text="{Binding EtaText}" FontSize="13" Foreground="{Binding TextMutedBrush}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,24,0,0" HorizontalAlignment="Left">
          <Button Theme="{StaticResource SkinQuietButton}" Background="Transparent" Foreground="{Binding TextBrush}" BorderBrush="{Binding TextMutedBrush}" Content="{Binding CancelButtonText}" Command="{Binding CancelCommand}" />
        </StackPanel>
      </Grid>

      <!-- COMPLETE -->
      <Grid Grid.Row="1" IsVisible="{Binding IsComplete}" RowDefinitions="*,Auto">
        <StackPanel Grid.Row="0" VerticalAlignment="Bottom" Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="{Binding CompleteHeading}" FontSize="30" FontWeight="Bold"
                     FontFamily="{Binding HeadingFont}" Foreground="{Binding TextBrush}" />
          <TextBlock Text="{Binding CompleteBody}" FontSize="17" TextWrapping="Wrap"
                     FontFamily="{Binding BodyFont}" Foreground="{Binding TextBrush}" />
          <ItemsControl ItemsSource="{Binding Warnings}" Margin="0,6,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="sys:String">
                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12.5" Foreground="#F5B32B" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,24,0,0" HorizontalAlignment="Left">
          <Button Theme="{StaticResource SkinPrimaryButton}" Background="{Binding AccentBrush}" Foreground="White" Content="{Binding PrimaryButtonText}" Command="{Binding PrimaryCommand}" />
          <Button Theme="{StaticResource SkinQuietButton}" Background="Transparent" Foreground="{Binding TextBrush}" BorderBrush="{Binding TextMutedBrush}" Content="{Binding ExitButtonText}" Command="{Binding ExitCommand}" />
        </StackPanel>
      </Grid>

      <!-- FAILED -->
      <Grid Grid.Row="1" IsVisible="{Binding IsFailed}" RowDefinitions="*,Auto">
        <StackPanel Grid.Row="0" VerticalAlignment="Bottom" Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="{Binding ErrorHeading}" FontSize="30" FontWeight="Bold"
                     FontFamily="{Binding HeadingFont}" Foreground="{Binding ErrorBrush}" />
          <TextBlock Text="{Binding ErrorBody}" FontSize="15" TextWrapping="Wrap"
                     FontFamily="{Binding BodyFont}" Foreground="{Binding TextBrush}" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,24,0,0" HorizontalAlignment="Left">
          <Button Theme="{StaticResource SkinQuietButton}" Background="Transparent" Foreground="{Binding TextBrush}" BorderBrush="{Binding TextMutedBrush}" Content="{Binding ExitButtonText}" Command="{Binding ExitCommand}" />
        </StackPanel>
      </Grid>

    </Grid>

    </Grid>
  </Border>
</UserControl>
