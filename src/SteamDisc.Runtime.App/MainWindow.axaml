<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skin="using:SteamDisc.Skin"
        x:Class="SteamDisc.Runtime.App.MainWindow"
        Width="900" Height="700" CanResize="False"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/SteamDisc.ico"
        Title="SteamDisc Setup">
  <skin:SkinHost x:Name="Host" />
</Window>
