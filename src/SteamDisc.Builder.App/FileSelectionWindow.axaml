<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SteamDisc.Builder.App.ViewModels"
        x:Class="SteamDisc.Builder.App.FileSelectionWindow"
        x:DataType="vm:FileSelectionViewModel"
        Width="640" Height="680" MinWidth="480" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/SteamDisc.ico"
        Title="Choose files to include">

  <Window.Styles>
    <Style Selector="TextBlock.reason">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="#F5B32B" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.size">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Opacity" Value="0.6" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16" RowSpacing="10">

    <StackPanel Grid.Row="0" Spacing="2">
      <TextBlock Text="{Binding HeaderTitle}" FontSize="16" FontWeight="SemiBold" />
      <TextBlock Text="Untick anything you don't want on the disc. Suggestions are pre-applied."
                 FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto">
      <Button Grid.Column="0" Content="Reset to suggested" Command="{Binding ResetToSuggestedCommand}"
              FontSize="12" Padding="10,4" Margin="0,0,8,0" />
      <Button Grid.Column="1" Content="Select all" Command="{Binding SelectAllCommand}"
              FontSize="12" Padding="10,4" />
      <Button Grid.Column="3" Content="Save selection…" Command="{Binding SaveCommand}"
              FontSize="12" Padding="10,4" />
    </Grid>

    <Border Grid.Row="2" CornerRadius="6" Background="#17181C" Padding="4">
      <TreeView ItemsSource="{Binding Roots}">
        <TreeView.ItemTemplate>
          <TreeDataTemplate x:DataType="vm:FileSelectionNodeViewModel" ItemsSource="{Binding Children}">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8" Margin="0,1">
              <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked, Mode=TwoWay}" IsThreeState="False" />
              <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Column="2" Classes="reason" Text="{Binding Reason}"
                         IsVisible="{Binding HasReason}" Margin="0,0,6,0" />
              <TextBlock Grid.Column="3" Classes="size" Text="{Binding SizeText}" />
            </Grid>
          </TreeDataTemplate>
        </TreeView.ItemTemplate>
      </TreeView>
    </Border>

    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
      <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
        <TextBlock Text="{Binding Summary}" FontSize="12" Opacity="0.85" TextWrapping="Wrap" />
        <TextBlock Text="{Binding SaveHint}" FontSize="12" Foreground="#3FB950"
                   IsVisible="{Binding SaveHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>
      <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}" MinWidth="90" />
      <Button Grid.Column="2" Content="Done" Command="{Binding DoneCommand}" MinWidth="90"
              Classes="accent" />
    </Grid>

  </Grid>
</Window>
